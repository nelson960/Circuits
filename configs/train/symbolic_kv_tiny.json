{
  "run_name": "symbolic_kv_learnability_fast",
  "seed": 7,
  "device": "mps",
  "benchmark_dir": "data/generated/symbolic_kv_stream_learnability",
  "output_dir": "artifacts/runs/symbolic_kv_learnability_fast",
  "batch_size": 128,
  "num_steps": 12000,
  "log_every_steps": 50,
  "eval_every_steps": 1000,
  "checkpoint_every_steps": 1000,
  "num_workers": 0,
  "model": {
    "d_model": 128,
    "n_layers": 3,
    "n_heads": 4,
    "d_ff": 512,
    "dropout": 0.0,
    "max_seq_len": 96
  },
  "optimization": {
    "learning_rate": 0.0004,
    "weight_decay": 0.01,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip_norm": 1.0,
    "warmup_steps": 200,
    "schedule": {
      "kind": "constant"
    }
  },
  "evaluation": {
    "batch_size": 128,
    "max_eval_batches": 4,
    "max_analysis_batches": 2,
    "tracked_splits": ["validation_iid"],
    "analysis_splits": ["validation_iid"],
    "birth_thresholds": {
      "answer_accuracy": 0.9,
      "q": 0.2,
      "r": 0.2,
      "w": 1.0
    }
  },
  "checkpointing": {
    "save_step_checkpoints": false,
    "save_best_checkpoint": true,
    "best_checkpoint_split": "validation_iid",
    "best_checkpoint_metric": "answer_accuracy",
    "best_checkpoint_maximize": true
  }
}
